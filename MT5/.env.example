# MetaTrader 5 Terminal Configuration
# -----------------------------------

# MT5 Account Number (Must be a number. Use 0 if not logged in)
MT5_ACCOUNT_NUMBER=0

# MT5 Account Password
MT5_PASSWORD=

# MT5 Broker Server Name (e.g., Deriv-Demo, IC-Markets-Demo)
MT5_SERVER=

# VNC Access (For viewing the terminal in a browser)
VNC_USER=mt5_user
VNC_PASSWORD=password